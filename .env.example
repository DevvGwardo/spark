# CloudChat Configuration
# Copy this file to `.env` and fill in whatever you need.
# All variables are optional — CloudChat works with sensible defaults.

# ---- Frontend ----
# Override the API server URL (defaults to http://localhost:3001)
# VITE_API_URL=http://localhost:3001

# ---- Hermes bridge ----
# Bridge port (defaults to 3002)
# HERMES_PORT=3002

# URL the API server uses to reach the bridge
# HERMES_BRIDGE_URL=http://localhost:3002/v1

# Where the real Hermes agent is installed (only needed if HERMES_AGENT_DIR
# differs from the default ~/.hermes/hermes-agent). See
# https://hermes-agent.nousresearch.com for install instructions.
# HERMES_AGENT_DIR=/path/to/hermes-agent

# Hermes data directory — holds auth.json, state.db, etc.
# HERMES_HOME=$HOME/.hermes

# Default toolsets (comma-separated). Options: web, browser, terminal,
# files, code_execution, vision
# HERMES_TOOLSETS=web,browser,terminal

# Default model for Hermes agent mode
# HERMES_DEFAULT_MODEL=meta-llama/llama-4-maverick

# Max tool-call iterations per turn
# HERMES_MAX_ITERATIONS=60

# ---- Provider keys (fallbacks) ----
# Preferred path is `hermes auth login` (writes to ~/.hermes/auth.json).
# These env vars are only used if no credential is found in auth.json.
# HERMES_OPENROUTER_KEY=sk-or-...
# HERMES_MINIMAX_KEY=...
