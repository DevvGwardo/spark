  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "analyze": "vite build --mode analyze",
    "build:dev": "vite build --mode development",
    "icons": "bash scripts/generate-icons.sh",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "server": "tsx server/index.ts",
    "electron:dev": "electron-vite dev",
    "electron:build": "electron-vite build && electron-builder --mac",
    "electron:build:win": "electron-vite build && electron-builder --win",
    "electron:build:all": "electron-vite build && electron-builder --mac --win",
    "electron:publish": "electron-vite build && electron-builder --mac --publish always",
    "electron:publish:win": "electron-vite build && electron-builder --win --publish always",
    "electron:publish:all": "electron-vite build && electron-builder --mac --win --publish always",
    "test:e2e": "npx playwright test --config playwright-electron.config.ts",
    "test:e2e:headed": "npx playwright test --config playwright-electron.config.ts --headed",
    "dev:electron": "npx concurrently -n server,bridge,electron -c blue,green,cyan \"npm run server\" \"cd hermes-bridge && .venv/bin/python main.py\" \"npm run electron:dev\""
  },
